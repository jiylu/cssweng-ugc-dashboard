generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id    String    @id
  email      String    @unique
  createdAt  DateTime  @default(now())
  first_name String
  last_name  String
  role       UserRoles
  is_active  Boolean   @default(true)
}

enum UserRoles {
  CLIENT
  CREATOR
}
