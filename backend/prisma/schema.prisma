generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id    String    @id
  email      String    @unique
  createdAt  DateTime  @default(now())
  first_name String
  last_name  String
  role       UserRoles
  is_active  Boolean   @default(true)
}

model Campaigns {
  campaign_id     String         @id @default(uuid())
  ugc_creator_id  String
  client_id       String?
  project_name    String
  description     String
  pricing         Decimal
  start_date      DateTime
  end_date        DateTime
  created_at      DateTime       @default(now())
  campaign_type   CampaignType
  campaign_status CampaignStatus @default(ACTIVE)

  proposals Proposals[]
}

model Proposals {
  proposal_id     String         @id @default(uuid())
  campaign_id     String
  campaign        Campaigns      @relation(fields: [campaign_id], references: [campaign_id])
  client_email    String
  client_comments String         @default("")
  proposal_status ProposalStatus @default(PENDING)
}

enum UserRoles {
  CLIENT
  CREATOR
}

enum CampaignType {
  COLLABORATION
  UGC
}

enum CampaignStatus {
  ACTIVE
  REJECTED
  COMPLETED
}

enum ProposalStatus {
  PENDING
  FOR_REVISION
  REJECTED
  ACCEPTED
}
