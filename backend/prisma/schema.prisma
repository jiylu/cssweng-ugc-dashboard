generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id    String    @id
  email      String    @unique
  createdAt  DateTime  @default(now())
  first_name String
  last_name  String
  role       UserRoles
  is_active  Boolean   @default(true)

  campaigns_as_creator Campaigns[] @relation("CreatorCampaigns")
  campaigns_as_client  Campaigns[] @relation("ClientCampaigns")

  activity_logs          ActivityLog[] @relation("ActivityLogUser")
  targeted_activity_logs ActivityLog[] @relation("ActivityLogTargetUser")
}

model Campaigns {
  campaign_id     String         @id @default(uuid())
  ugc_creator_id  String
  client_id       String?
  project_name    String
  description     String
  pricing         Decimal
  start_date      DateTime
  end_date        DateTime
  created_at      DateTime       @default(now())
  campaign_status CampaignStatus @default(ACTIVE)

  creator   User       @relation("CreatorCampaigns", fields: [ugc_creator_id], references: [user_id])
  client    User?      @relation("ClientCampaigns", fields: [client_id], references: [user_id])
  proposals Proposals[]
  deliverables Deliverables[]
}

model Proposals {
  proposal_id     String         @id @default(uuid())
  campaign_id     String
  client_email    String
  client_comments String         @default("")
  proposal_status ProposalStatus @default(PENDING)

  campaign Campaigns @relation(fields: [campaign_id], references: [campaign_id])
}

model Deliverables {
  deliverable_id    String          @id @default(uuid())
  campaign_id       String
  deliverable_title String
  description       String
  deadline          DateTime
  pricing           Decimal
  deliverable_type  DeliverableType

  campaign Campaigns @relation(fields: [campaign_id], references: [campaign_id])
}

model ActivityLog {
  log_id         String          @id @default(uuid())
  user_id        String
  target_user_id String
  entity_type    EntityType
  entity_id      String
  action         Action
  title          DeliverableType
  message        String
  is_read        Boolean
  created_at     DateTime

  user        User @relation("ActivityLogUser",       fields: [user_id],        references: [user_id])
  target_user User @relation("ActivityLogTargetUser", fields: [target_user_id], references: [user_id])
}

enum UserRoles {
  CLIENT
  CREATOR
}

enum DeliverableType {
  COLLABORATION
  UGC
}

enum CampaignStatus {
  ACTIVE
  REJECTED
  COMPLETED
}

enum ProposalStatus {
  PENDING
  FOR_REVISION
  REJECTED
  ACCEPTED
}

enum EntityType {
  CAMPAIGN
  SUBMISSION
  PAYMENT
}

enum Action {
  SUBMISSION
  APPROVE
  SIGNED
}
